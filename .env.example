# Copy to .env and fill in. Loaded by `wrangler dev`.

# Turso (libSQL). For local dev, point at a file: URL.
# For remote dev, use libsql://<db>-<org>.turso.io and set TURSO_AUTH_TOKEN.
TURSO_DATABASE_URL=file:./local.db
# TURSO_AUTH_TOKEN=

# Auth.js secret used to encrypt session JWT. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials. Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5173/auth/callback/google or http://localhost:8787/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
