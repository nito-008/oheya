{
  "name": "my-qwik-basic-starter",
  "description": "Demo app with sample routes",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/cloudflare-workers/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply bio-tower-dev --local",
    "db:migrate:prod": "wrangler d1 migrations apply bio-tower-dev --remote",
    "db:studio": "drizzle-kit studio",
    "deploy": "wrangler deploy",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "oxfmt",
    "fmt.check": "oxfmt --check",
    "lint": "tsc --noEmit && oxlint src/",
    "preview": "qwik build preview && vite preview --open",
    "serve": "wrangler dev",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@auth/qwik": "0.8.0",
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@cloudflare/workers-types": "^4.20251228.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "20.19.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-qwik": "^1.19.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "5.4.5",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "drizzle-orm": "^0.45.2"
  },
  "packageManager": "npm@11.12.1"
}