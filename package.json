{
  "name": "my-qwik-basic-starter",
  "private": true,
  "description": "Demo app with sample routes",
  "type": "module",
  "scripts": {
    "build": "npm run qwik build",
    "build.client": "vp build",
    "build.preview": "vp build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vp build -c adapters/cloudflare-workers/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply bio-tower-dev --local",
    "db:migrate:prod": "wrangler d1 migrations apply bio-tower-dev --remote",
    "db:studio": "drizzle-kit studio",
    "deploy": "wrangler deploy",
    "dev": "vp dev --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "vp fmt",
    "fmt.check": "vp fmt --check",
    "lint": "tsc --noEmit && vp lint src/",
    "preview": "qwik build preview && vp preview --open",
    "serve": "wrangler dev",
    "start": "vp dev --open --mode ssr",
    "qwik": "qwik",
    "prepare": "vp config"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@auth/qwik": "0.8.0",
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@cloudflare/workers-types": "^4.20251228.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "20.19.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-qwik": "^1.19.2",
    "tailwindcss": "^4.2.2",
    "typescript": "5.4.5",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^3.0.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "packageManager": "npm@11.11.0",
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime"
}
